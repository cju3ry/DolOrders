skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0

!define ENTITY_COLOR #E8F5E9
!define DTO_COLOR #FFF3E0
!define STORAGE_COLOR #E3F2FD
!define REPOSITORY_COLOR #F3E5F5
