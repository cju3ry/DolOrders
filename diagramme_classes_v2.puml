ProduitMapper ..> ProduitApiReponseDto : convertit >
ProduitMapper ..> Produit : produit >

' ===== PACKAGE REPOSITORY =====
package "repository" REPOSITORY_COLOR {
    class ClientApiRepository {
        - context: Context
        - requestQueue: RequestQueue
        - gson: Gson
        __
        + ClientApiRepository(Context)
        + synchroniserDepuisApi(ClientCallback): void
        + envoyerClient(Client, ClientEnvoiCallback): void
        + envoyerClientVersHistorique(Client, String, ClientHistoriqueCallback): void
        + recupererIdUtilisateur(UserIdCallback): void
        - envoyerClientAvecUserId(Client, String, ClientEnvoiCallback): void
        - envoyerVersHistorique(Client, String, String, ClientEnvoiCallback): void
        - parseJsonResponse(JSONArray): List<Client>
        - creerJsonClient(Client, String): JSONObject
        - getBaseUrl(): String
        - getApiKey(): String
        - getUsername(): String
        ..Interfaces..
        + <<interface>> ClientCallback
        + <<interface>> ClientEnvoiCallback
        + <<interface>> ClientHistoriqueCallback
        + <<interface>> UserIdCallback
    }

    class CommandeApiRepository {
        - context: Context
        - requestQueue: RequestQueue
        __
        + CommandeApiRepository(Context)
        + envoyerCommandeVersModuleNatif(Commande, CommandeNativeEnvoiCallback): void
        + envoyerCommandeVersHistoriqueAvecId(Commande, String, CommandeEnvoiCallback): void
        + envoyerCommandeVersHistoriqueSansId(Commande, CommandeEnvoiCallback): void
        - creerJsonCommandeNative(Commande): JSONObject
        - creerJsonLigneHistorique(Commande, LigneCommande, String, String): JSONObject
        - getBaseUrl(): String
        - getApiKey(): String
        - getUsername(): String
        ..Interfaces..
        + <<interface>> CommandeEnvoiCallback
        + <<interface>> CommandeNativeEnvoiCallback
    }

    class ProduitRepository {
        - context: Context
        - requestQueue: RequestQueue
        - gson: Gson
        __
        + ProduitRepository(Context)
        + synchroniserDepuisApi(ProduitCallback): void
        - parseJsonResponse(JSONArray): List<Produit>
        - getBaseUrl(): String
        - getApiKey(): String
        ..Interface..
        + <<interface>> ProduitCallback
    }
}

ClientApiRepository ..> Client : envoie/récupère >
