    package "stockage" STORAGE_COLOR {

        package "client" {
            class GestionnaireStockageClient {
                - {static} DEFAULT_FILE_NAME: String
                + {static} API_CLIENTS_FILE: String
                - context: Context
                - gson: Gson
                - fileName: String
                __
                + GestionnaireStockageClient(Context)
                + GestionnaireStockageClient(Context, String)
                + saveClients(List<Client>): boolean
                + loadClients(): List<Client>
                + addClient(Client): boolean
                + deleteClient(Client): boolean
                + modifierClient(Client): boolean
                + clearClients(): boolean
                + hasStoredClients(): boolean
                + getClientCount(): int
                # getFileName(): String
            }

            class AdaptateurStockageClient {
                + write(JsonWriter, Client): void
                + read(JsonReader): Client
            }
        }

        package "commande" {
            class GestionnaireStockageCommande {
                - {static} FILE_NAME: String
                - context: Context
                - gson: Gson
                __
                + GestionnaireStockageCommande(Context)
                + saveCommandes(List<Commande>): boolean
                + loadCommandes(): List<Commande>
                + addCommande(Commande): boolean
                + deleteCommande(Commande): boolean
                + modifierCommande(Commande): boolean
                + deleteCommandesByClient(String): boolean
                + clearCommandes(): boolean
                + hasStoredCommandes(): boolean
                # getFileName(): String
            }

            class AdapteurStockageCommande {
                + write(JsonWriter, Commande): void
                + read(JsonReader): Commande
            }
        }

        package "produit" {
            class ProduitStorageManager {
                - {static} FILE_NAME: String
                - context: Context
                - gson: Gson
                __
                + ProduitStorageManager(Context)
                + saveProduits(List<Produit>): boolean
                + loadProduits(): List<Produit>
                + getProduitById(String): Produit
                + clearProduits(): boolean
                + hasStoredProduits(): boolean
            }

            class ProduitTypeAdapter {
                + write(JsonWriter, Produit): void
                + read(JsonReader): Produit
            }
        }
    }
}

GestionnaireStockageClient ..> Client : gère >
GestionnaireStockageClient ..> AdaptateurStockageClient : utilise >
GestionnaireStockageCommande ..> Commande : gère >
GestionnaireStockageCommande ..> AdapteurStockageCommande : utilise >
ProduitStorageManager ..> Produit : gère >
