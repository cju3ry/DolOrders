' ===== PACKAGE MAPPER =====
package "mapper" DTO_COLOR {
    class ClientApiMapper {
        - ClientApiMapper()
        + {static} fromDto(ClientApiReponseDto): Client
        - {static} formatPhoneNumber(String): String
    }

    class ProduitMapper {
        - ProduitMapper()
        + {static} fromDto(ProduitApiReponseDto): Produit
